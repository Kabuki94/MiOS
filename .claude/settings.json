{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Claude Code project settings for CloudWS-bootc. This file is checked into the repo so every dev who opens the project inherits the same tool permissions. User-specific overrides go in .claude/settings.local.json (which is gitignored).",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git fetch:*)",

      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",

      "Bash(shellcheck:*)",
      "Bash(hadolint:*)",
      "Bash(yamllint:*)",
      "Bash(shfmt -d:*)",
      "Bash(prettier --check:*)",
      "Bash(taplo check:*)",
      "Bash(taplo lint:*)",

      "Bash(just --list)",
      "Bash(just --summary)",

      "Bash(podman build --target ctx:*)",
      "Bash(podman images)",
      "Bash(podman inspect:*)"
    ],

    "deny": [
      "Bash(git push:*)",
      "Bash(podman push:*)",
      "Bash(cosign sign:*)",
      "Bash(cosign upload:*)",
      "Bash(gh auth:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo rm:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(bootc install:*)",
      "Bash(bootc switch:*)",

      "Edit(docs/PACKAGES.md)",
      "Edit(VERSION)",
      "Edit(CHANGELOG.md)",
      "Edit(.ai-context/knowledge-base.md)",

      "Edit(.github/workflows/build-sign.yml)",
      "Edit(.github/workflows/build-artifacts.yml)",

      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(~/.ssh/**)",
      "Write(~/.docker/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.config/gh/**)"
    ],

    "ask": [
      "Bash(podman build:*)",
      "Bash(just build:*)",
      "Bash(just iso:*)",
      "Bash(just all:*)",
      "Bash(bootc-image-builder:*)",
      "Bash(semanage:*)",
      "Bash(setsebool:*)",
      "Bash(mokutil:*)",
      "Bash(sbctl:*)",
      "Bash(systemctl:*)",
      "Bash(virsh:*)",

      "Edit(Containerfile)",
      "Edit(kargs.d/**)",
      "Edit(system_files/etc/**)",
      "Edit(.github/workflows/**)",
      "Edit(scripts/lib/**)"
    ]
  },

  "env": {
    "CLOUDWS_REPO": "github.com/Kabuki94/CloudWS-bootc",
    "CLOUDWS_IMAGE": "ghcr.io/kabuki94/cloudws-bootc:latest",
    "CLOUDWS_BASE_PRIMARY": "ghcr.io/ublue-os/ucore-hci:stable-nvidia",
    "CLOUDWS_BASE_SECONDARY": "quay.io/fedora/fedora-bootc:rawhide"
  },

  "includeCoAuthoredBy": true,

  "_notes": [
    "Permissions follow the CLAUDE.md §4 deliverable contract: Claude Code may freely inspect the repo but must ask before mutating anything that lands in a build artifact or a signed image.",
    "The deny list covers the files CLAUDE.md §8 says must not be touched without explicit human review: VERSION, CHANGELOG.md, docs/PACKAGES.md, the historical audit log, and signing/artifact workflows.",
    "Slash commands live in .claude/commands/. Sub-agents live in .claude/agents/. Both are checked in so the whole team (currently: Kabu) gets the same workflow."
  ]
}
