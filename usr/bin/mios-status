#!/bin/bash
set -euo pipefail

JSON_MODE=false
for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then JSON_MODE=true; fi
done

VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")
BOOTC_MANAGED=true
if [[ "$VIRT" == "wsl" || "$VIRT" == container* ]] || [[ -f "/.containerenv" || -f "/.dockerenv" ]]; then
    BOOTC_MANAGED=false
fi

if [[ "$JSON_MODE" == "true" ]]; then
    SERVICES=()
    for svc in gdm cockpit.socket sshd libvirtd.socket virtnetworkd.socket virtqemud.socket \
               firewalld tuned k3s gnome-remote-desktop avahi-daemon; do
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            SERVICES+=("\"$svc\": \"active\"")
        elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
            SERVICES+=("\"$svc\": \"enabled\"")
        fi
    done
    SVCS_JSON=$(IFS=,; echo "${SERVICES[*]}")
    printf '{"hostname": "%s", "uptime": "%s", "kernel": "%s", "platform": "%s", "bootc_managed": %s, "services": {%s}}\n' \
        "$(hostname)" \
        "$(uptime -p 2>/dev/null || uptime)" \
        "$(uname -r)" \
        "$VIRT" \
        "$BOOTC_MANAGED" \
        "$SVCS_JSON"
    exit 0
fi

echo "MiOS v0.1.3 — System Status"
echo "════════════════════════════════"
echo ""
echo "Hostname:  $(hostname)"
echo "Uptime:    $(uptime -p 2>/dev/null || uptime)"
echo "Kernel:    $(uname -r)"
echo "Platform:  $VIRT"
if [[ "$BOOTC_MANAGED" == "true" ]]; then
    echo "bootc:     $(bootc status 2>/dev/null | head -3 || echo 'N/A')"
else
    echo "bootc:     N/A — WSL2/container import (not bootc-managed)"
fi
echo ""
echo "Services:"
for svc in gdm cockpit.socket sshd libvirtd.socket virtnetworkd.socket virtqemud.socket \
           firewalld tuned k3s gnome-remote-desktop avahi-daemon; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        printf "  + %-30s active\n" "$svc"
    elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
        printf "  o %-30s enabled (inactive)\n" "$svc"
    fi
done
echo ""
echo "Podman:"
podman system df 2>/dev/null || echo "  Not available"
