#!/bin/bash
# MiOS v0.1.3 — Unified management CLI
set -euo pipefail
VERSION="0.1.3"
CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    --help|-h|help)
        echo ""
        echo "  MiOS v${VERSION} — Unified Management CLI"
        echo "  ══════════════════════════════════════════"
        echo ""
        echo "  USAGE: mios <command> [options]"
        echo ""
        echo "  INITIALIZATION"
        echo "    init            Initialize user-space (~/.config/mios)"
        echo "    deploy          System-wide FHS deployment (/usr/src/mios)"
        echo "    live-init       Live ISO initiation (overlay onto root)"
        echo ""
        echo "  SYSTEM"
        echo "    update          Check for & apply OS updates (bootc)"
        echo "    rebuild         Clone repo, build from source, push to GHCR"
        echo "    build           Local OCI build only (no push)"
        echo "    preflight       Check and install build prerequisites"
        echo "    deploy-image    Switch to a different MiOS image (deploy)"
        echo "    backup          Snapshot /etc + /var/home"
        echo "    status          Show system & service status"
        echo "    assess          Run automated system assessment"
        echo ""
        echo "  DESKTOP"
        echo "    toggle-headless  Switch between desktop and headless mode"
        echo "    dash             Dynamic auto-updating diagnostic dashboard"
        echo "    test             Run system health checks"
        echo ""
        echo "  VIRTUALIZATION"
        echo "    vfio-toggle      Bind/unbind GPU from vfio-pci"
        echo "    vfio-check       Validate VFIO passthrough readiness"
        echo "    iommu-groups     List IOMMU groups (iommu)"
        echo "    cpu-isolate      Configure core isolation (X3D optimized)"
        echo ""
        echo "  CONTAINERS"
        echo "    gc               Run Podman garbage collection now"
        echo "    gc-status        Show Podman disk usage"
        echo ""
        echo "  AI & LLM"
        echo "    ai               Show status of Ollama and AIChat"
        echo "    ai-logs          Tail Ollama container logs"
        echo "    ai-pull <m>      Pull a model into Ollama"
        echo ""
        echo "  SECURITY"
        echo "    scan-malware     ClamAV container scan of /home"
        echo "    sb-audit         Secure Boot CA 2023 readiness audit"
        echo "    sb-keygen        Generate Machine Owner Key (MOK)"
        echo "    tpm-enroll       Enroll TPM 2.0 for passwordless boot"
        ;;
    version|--version|-v)
        echo "MiOS v${VERSION}"
        ;;
    init)        exec /usr/share/mios/tools/mios-init.sh user "$@" ;;
    deploy)      exec /usr/share/mios/tools/mios-init.sh deploy "$@" ;;
    live-init)   exec /usr/share/mios/tools/mios-init.sh live-init "$@" ;;
    update)      exec /usr/bin/mios-update "$@" ;;
    rebuild)     exec /usr/bin/mios-rebuild "$@" ;;
    build)       exec /usr/bin/mios-build "$@" ;;
    preflight)   exec /usr/libexec/mios/preflight "$@" ;;
    deploy-image) exec /usr/bin/mios-deploy "$@" ;;
    backup)      exec /usr/bin/mios-backup "$@" ;;
    status)      exec /usr/bin/mios-status "$@" ;;
    assess)      exec /usr/libexec/mios/assess "$@" ;;
    toggle-headless|toggle_headless) exec /usr/libexec/mios/mios-toggle-headless "$@" ;;
    dash)        exec /usr/libexec/mios/dash ;;
    test)        exec /usr/libexec/mios/mios-test "$@" ;;
    vfio-toggle|vfio_toggle) exec /usr/bin/mios-vfio-toggle "$@" ;;
    vfio-check|vfio_check)  exec /usr/bin/mios-vfio-check "$@" ;;
    cpu-isolate|cpu_isolate) exec /usr/bin/mios-cpu-isolate "$@" ;;
    iommu-groups|iommu) exec /usr/bin/iommu-groups "$@" ;;
    gc)          exec /usr/libexec/mios/mios-podman-gc "$@" ;;
    gc-status|gc_status)   podman system df 2>/dev/null || echo "Podman not available" ;;
    ai)
        echo "Ollama Status:"
        systemctl status ollama.service --no-pager || true
        echo ""
        echo "AIChat Version:"
        aichat --version || echo "AIChat not installed"
        ;;
    ai-logs|ai_logs)     exec podman logs -f ollama ;;
    ai-pull|ai_pull)
        model="${1:-deepseek-coder-v2:lite}"
        echo "Pulling model $model..."
        exec podman exec -it ollama ollama pull "$model"
        ;;
    scan-malware|scan_malware|scan)
        podman run --rm -v /:/scan:ro docker.io/clamav/clamav:latest \
            clamscan -r /scan/home --max-filesize=100M --max-scansize=500M 2>/dev/null
        ;;
    sb-audit|sb_audit)    exec /usr/libexec/mios/sb-audit ;;
    sb-keygen|sb_keygen)   exec /usr/libexec/mios/sb-keygen ;;
    tpm-enroll|tpm_enroll)  exec /usr/libexec/mios/tpm-enroll ;;
    sysext)      exec systemd-sysext "$@" ;;
    role)        exec /usr/libexec/mios/role-apply "$@" ;;
    motd)        exec /usr/libexec/mios/motd ;;
    *)
        echo "Unknown command: $CMD"
        echo "Run 'mios --help' for available commands."
        exit 1
        ;;
esac
