#!/bin/bash
# MiOS v0.1.3 — Source Rebuild & Push
# Synchronizes with latest upstream before building.
set -euo pipefail

MIOS_SRC_DIR="/usr/src/mios"
if [[ ! -d "${MIOS_SRC_DIR}/.git" ]]; then
    MIOS_SRC_DIR="${MIOS_DIR:-$HOME/MiOS}"
fi

echo "MiOS — Rebuilding from source..."
if [ ! -d "$MIOS_SRC_DIR" ]; then
    git clone https://github.com/Kabuki94/MiOS-bootstrap.git "$MIOS_SRC_DIR"
else
    cd "$MIOS_SRC_DIR" && git pull
fi

cd "$MIOS_SRC_DIR"
if command -v just &>/dev/null; then
    just all
else
    podman build --progress=tty --no-cache --build-arg MAKEFLAGS="-j$(nproc)" -t localhost/mios:latest .
    podman push localhost/mios:latest ghcr.io/kabuki94/mios:latest
fi
