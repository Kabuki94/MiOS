#!/bin/bash
# MiOS v0.1.3 — Local OCI Build
set -euo pipefail

# Ensure source is synced
/usr/src/mios/tools/sync-source.sh || ./tools/sync-source.sh || true

echo "MiOS — Local build..."
cd "/usr/src/mios" 2>/dev/null || cd "."
podman build --progress=tty --no-cache --build-arg MAKEFLAGS="-j$(nproc)" -t localhost/mios:latest .
