#!/bin/bash
set -euo pipefail

JSON_MODE=false
CHECK_ONLY=false

for arg in "$@"; do
    case $arg in
        --json) JSON_MODE=true ;;
        --check-only) CHECK_ONLY=true ;;
    esac
done

# Platform gate — bootc upgrade only works on bootc-managed (bare metal / VM) deployments.
# WSL2 instances and OCI container imports use podman export / wsl --import to upgrade.
VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")
if [[ "$VIRT" == "wsl" || "$VIRT" == container* ]] || [[ -f "/.containerenv" || -f "/.dockerenv" ]]; then
    if [[ "$JSON_MODE" == "true" ]]; then
        printf '{"status": "not-bootc-managed", "platform": "%s", "message": "WSL2 and container imports cannot be upgraded via bootc. Re-export and re-import the latest OCI image."}\n' "$VIRT"
    else
        printf 'INFO: Running as %s (WSL2 or container import).\n' "$VIRT"
        echo "  bootc upgrade cannot manage this environment."
        echo "  To upgrade, re-export and re-import the latest OCI image:"
        echo "    podman export \$(podman create ghcr.io/kabuki94/mios:latest) -o mios.tar"
        echo "    wsl --import MiOS-OS /path/to/install mios.tar"
    fi
    exit 0
fi

if [[ "$JSON_MODE" == "false" ]]; then
    echo "MiOS v2.1.0 — Checking for updates..."
fi

# Parse origin from bootc status --format=json (stable API; never parse bootc upgrade stdout)
STATUS_JSON=$(bootc status --format=json 2>/dev/null || echo '{}')
ORIGIN=$(echo "$STATUS_JSON" \
    | python3 -c "
import sys, json
d = json.load(sys.stdin)
b = d.get('status', {}).get('booted') or {}
img = b.get('image') or {}
t = img.get('image') or {}
print(t.get('image', 'unknown'))
" 2>/dev/null || echo "unknown")

if echo "$ORIGIN" | grep -q "localhost"; then
    if [[ "$JSON_MODE" == "true" ]]; then
        echo '{"status": "error", "error": "origin_localhost", "message": "Update origin is localhost - switch to GHCR required"}'
        exit 1
    else
        echo "WARNING: Update origin is localhost — switching to GHCR..."
        sudo bootc switch ghcr.io/kabuki94/mios:latest
    fi
fi

if [[ "$CHECK_ONLY" == "true" ]]; then
    STAGED=$(echo "$STATUS_JSON" \
        | python3 -c "import sys,json; d=json.load(sys.stdin); print('yes' if d.get('status',{}).get('staged') else 'no')" \
        2>/dev/null || echo "no")
    if [[ "$JSON_MODE" == "true" ]]; then
        if [[ "$STAGED" == "yes" ]]; then
            echo "{\"status\": \"staged\", \"current_image\": \"$ORIGIN\", \"message\": \"An update is already staged and pending reboot.\"}"
        else
            echo "{\"status\": \"up_to_date\", \"current_image\": \"$ORIGIN\"}"
        fi
    else
        echo "Current image: $ORIGIN"
        [[ "$STAGED" == "yes" ]] && echo "Notice: An update is already staged — reboot to apply."
    fi
    exit 0
fi

if [[ "$JSON_MODE" == "true" ]]; then
    sudo bootc upgrade 2>&1 || true
    # Re-read status after upgrade — staged field is the reliable indicator
    STAGED=$(bootc status --format=json 2>/dev/null \
        | python3 -c "import sys,json; d=json.load(sys.stdin); print('yes' if d.get('status',{}).get('staged') else 'no')" \
        2>/dev/null || echo "no")
    if [[ "$STAGED" == "yes" ]]; then
        echo "{\"status\": \"staged\", \"current_image\": \"$ORIGIN\", \"message\": \"New update staged. Reboot required.\"}"
    else
        echo "{\"status\": \"up_to_date\", \"current_image\": \"$ORIGIN\"}"
    fi
else
    echo "Current image: $ORIGIN"
    sudo bootc upgrade
    echo ""
    echo "If an update was staged, reboot to apply: sudo reboot"
fi
