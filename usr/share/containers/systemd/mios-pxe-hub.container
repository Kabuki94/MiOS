[Unit]
Description=MiOS PXE Hub (netboot.xyz)
After=network-online.target
Wants=network-online.target

[Container]
HttpProxy=false
GlobalArgs=--storage-opt=additionalimagestore=/usr/lib/bootc/storage
Image=ghcr.io/netbootxyz/netbootxyz:latest
ContainerName=mios-pxe-hub
# Map persistent storage for ISOs and custom menus
Volume=/var/lib/mios/pxe/config:/config:Z
Volume=/var/lib/mios/pxe/assets:/assets:Z
# Expose required PXE/Network Boot ports
# 69/udp (TFTP), 80/tcp (HTTP Assets), 8080/tcp (Web UI)
PublishPort=69:69/udp
PublishPort=80:80/tcp
PublishPort=8080:8080/tcp
# Enable host networking mode is often preferred for PXE/DHCP proxy scenarios,
# but we'll try bridge with explicit ports first for better isolation.
# If DHCP proxy is needed, users can toggle to Network=host.
Environment=PORT=80
Environment=WEB_PORT=8080
Restart=always
AutoUpdate=registry
Notify=healthy
HealthCmd=curl -f http://localhost:8080 || exit 1

[Service]
# Ensure directories exist
ExecStartPre=/usr/bin/mkdir -p /var/lib/mios/pxe/config /var/lib/mios/pxe/assets

[Install]
WantedBy=multi-user.target
