#!/bin/bash
# CloudWS v2.0 — MOTD Dashboard
# Shows management interfaces, service statuses, and clickable links.
# Displayed on TTY login and terminal open via profile.d.
[[ $- != *i* ]] && exit 0
[[ -n "$CLOUDWS_NO_MOTD" ]] && exit 0

_ip() { ip -4 route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1; }
IP=$(_ip); [[ -z "$IP" ]] && IP="127.0.0.1"
HN=$(hostname -s 2>/dev/null || echo "CloudWS")
_l() { printf '\e]8;;%s\e\\%s\e]8;;\e\\' "$1" "$2"; }
C=$'\033[0;36m';W=$'\033[1;37m';G=$'\033[0;32m';D=$'\033[0;90m';N=$'\033[0m'
_s() {
    if systemctl is-active --quiet "$1" 2>/dev/null; then
        printf '%s' "${G}●${N}"
    else
        printf '%s' "${D}○${N}"
    fi
}

echo ""
printf '%s\n' "${C}════════════════════════════════════════════════════════════${N}"
printf '%s\n' "${W}  CloudWS v2.0${N}  ${D}${HN} — ${IP}${N}"
printf '%s\n' "${C}════════════════════════════════════════════════════════════${N}"
echo ""
printf '%s\n' "${W}  Management${N}"
printf '%s\n' "  $(_s cockpit.socket)  Cockpit           $(_l "https://${IP}:9090" "https://${IP}:9090")"
printf '%s\n' "  $(_s sshd)  SSH               $(_l "ssh://${IP}" "${IP}:22")"

# RDP — check both GRD and xRDP
if systemctl is-active --quiet gnome-remote-desktop 2>/dev/null; then
    printf '%s\n' "  ${G}●${N}  Remote Desktop    $(_l "rdp://${IP}:3389" "${IP}:3389") ${D}(GRD)${N}"
elif systemctl is-active --quiet xrdp 2>/dev/null; then
    printf '%s\n' "  ${G}●${N}  Remote Desktop    $(_l "rdp://${IP}:3389" "${IP}:3389") ${D}(xRDP)${N}"
else
    printf '%s\n' "  ${D}○${N}  Remote Desktop    ${D}inactive${N}"
fi

# Guacamole
if systemctl is-active --quiet cloudws-guacamole.service 2>/dev/null || \
   podman ps --format '{{.Names}}' 2>/dev/null | grep -q cloudws-guacamole; then
    printf '%s\n' "  ${G}●${N}  Browser Desktop   $(_l "http://${IP}:8080/guacamole/" "http://${IP}:8080/guacamole/")"
fi

echo ""
printf '%s\n' "${W}  Infrastructure${N}"
printf '%s\n' "  $(_s firewalld)  Firewall          ${D}firewall-cmd --list-all${N}"
printf '%s\n' "  $(_s podman.socket)  Podman            ${D}$(podman ps -q 2>/dev/null | wc -l) containers${N}"
printf '%s\n' "  $(_s libvirtd.socket)  Libvirt           ${D}virt-manager / virsh${N}"

# Optional services — only show if enabled
systemctl is-active --quiet k3s.service 2>/dev/null && \
    printf '%s\n' "  ${G}●${N}  K3s API           $(_l "https://${IP}:6443" "https://${IP}:6443")"
systemctl is-active --quiet ceph-mgr@*.service 2>/dev/null && \
    printf '%s\n' "  ${G}●${N}  Ceph Dashboard    $(_l "https://${IP}:8443" "https://${IP}:8443")"
systemctl is-active --quiet avahi-daemon 2>/dev/null && \
    printf '%s\n' "  ${G}●${N}  mDNS             ${D}${HN}.local${N}"

# Hyper-V enhanced session
VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")
if [ "$VIRT" = "microsoft" ]; then
    systemctl is-active --quiet xrdp 2>/dev/null && \
        printf '%s\n' "  ${G}●${N}  Hyper-V Enhanced  ${D}vsock:3389${N}"
fi

echo ""
printf '%s\n' "  ${D}cloudws --help | export CLOUDWS_NO_MOTD=1 to hide${N}"
echo ""
