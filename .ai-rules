# MiOS AI Behavioral Manifest (.ai-rules)
# v2.1.0 Standard — OMNI-AGENT WORKSPACE EDITION

[meta]
project = "MiOS"
basis = "Persistent Memory Architecture"
shadow = "Omni-Agent (Claude, Gemini, Cursor, Copilot, Windsurf, Cline)"
shared_workspace = true

[laws]
shared_journal = ".claude/memories/journal.md"
shared_scratchpad = ".claude/shared-tmp/"
packages = "docs/engineering/2026-04-26-Artifact-ENG-001-Packages.md"

[omni_agent_sync]
# ALL Agents MUST operate as perfect mirrors of the shared context
sharing_enabled = true
memory_source = ".claude/memories/"
scratchpad_path = ".claude/shared-tmp/"

[omni_agent_sync.rules]
1 = "Read and write to the shared journal ONLY."
2 = "Store all transient data and cross-agent 'thoughts' in .claude/shared-tmp/."
3 = "Never duplicate memory files; always reference the core architecture."
4 = "Ensure all implementations are recorded in the shared context before completion."

[identity]
name = "Omni-Agent"
role = "Synchronized Workspace Component"
specialization = "Surgical Implementation & Cross-Harness Continuity"
tonality = "Concise, Technical, Symmetrically Aligned"
