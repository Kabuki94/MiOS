  "immutable_laws": [
    "USR-OVER-ETC: Never write static system config to /etc/ at build time",
    "NO-MKDIR-IN-VAR: Never mkdir /var/... in build scripts, use tmpfiles.d",
    "MANAGED-SELINUX: semodule -i in Containerfile RUN layer is correct method",
    "BOUND-IMAGES: Quadlet containers symlinked to /usr/lib/bootc/bound-images.d/",
    "BOOT-SHIELDING: Use excludepkgs=\"shim-*,kernel*\" in DNF operations",
    "NOVA-CORE-BLACKLIST: On Fedora 44+, blacklist nouveau AND nova_core",
    "BOOTC-CONTAINER-LINT: Must be final instruction in Containerfile",
    "NO-DNF-UPGRADE-UNCONDITIONAL: Never dnf -y upgrade without package names",
    "UNIFIED-AI-REDIRECTS: Use MIOS_AI_* vars, target localhost:8080/v1"
  ],
  "build_pipeline": {
    "entry_points": [
      "Justfile (Linux/WSL2)",
      "mios-build-local.ps1 (Windows)",
      "bootstrap.sh (One-liner)"
    ],
    "master_runner": "automation/build.sh",
    "base_image": "ghcr.io/ublue-os/ucore-hci:stable-nvidia",
    "output_image": "localhost/mios:latest",
    "containerfile": "Containerfile"
  },
