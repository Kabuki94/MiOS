{
  "$schema": "https://json.schemastore.org.ai/foundation-code-settings.json",
  "env": {
    "MIOS_REPO": "github.com/Kabuki94/mios",
    "MIOS_IMAGE": "ghcr.io/kabuki94/mios:latest",
    "MIOS_BASE_PRIMARY": "ghcr.io/ublue-os/ucore-hci:stable-nvidia",
    "MIOS_BASE_SECONDARY": "quay.io/fedora/fedora-bootc:rawhide",
    "AI_ARCH_BASELINE": "v0.1.3",
    "AI_DNF_POLICY": "--setopt=install_weak_deps=False",
    "AI_WSL_GATING": "ConditionVirtualization=!wsl",
    "AI_OVERLAY_PATH": "",
    "AI_PKG_SOURCE": "specs/PACKAGES.md",
    "AI_COSIGN_PIN": "v0.1.3",
    "AI_WORKSPACE_TYPE": "bootable-container",
    "AI_JOURNALING_LAW": "MANDATORY"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git fetch:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(shellcheck:*)",
      "Bash(hadolint:*)",
      "Bash(yamllint:*)",
      "Bash(shfmt -d:*)",
      "Bash(prettier --check:*)",
      "Bash(taplo check:*)",
      "Bash(taplo lint:*)",
      "Bash(just --list)",
      "Bash(just --summary)",
      "Bash(podman build --target ctx:*)",
      "Bash(podman images)",
      "Bash(podman inspect:*)",
      "Bash(git -C \"d:/Documents/Github/MiOS\" log --oneline -5)",
      "Bash(GIT_TERMINAL_PROMPT=0 GIT_SSH_COMMAND=\"ssh -o BatchMode=yes\" git -C \"d:/Documents/Github/MiOS\" status --short)",
      "Bash(echo \"EXIT:$?\")",
      "WebSearch(*)",
      "WebFetch(*)",
      "Bash(git commit -m ' *)",
      "Bash(git rm *)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(podman push:*)",
      "Bash(cosign sign:*)",
      "Bash(cosign upload:*)",
      "Bash(gh auth:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo rm:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(bootc install:*)",
      "Bash(bootc switch:*)",
      "Edit(specs/PACKAGES.md)",
      "Edit(VERSION)",
      "Edit(CHANGELOG.md)",
      "Edit(specs/memory/**)",
      "Edit(.github/workflows/build-sign.yml)",
      "Edit(.github/workflows/build-artifacts.yml)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(~/.ssh/**)",
      "Write(~/.docker/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.config/gh/**)"
    ],
    "ask": [
      "Bash(podman build:*)",
      "Bash(just build:*)",
      "Bash(just iso:*)",
      "Bash(just all:*)",
      "Bash(bootc-image-builder:*)",
      "Bash(semanage:*)",
      "Bash(setsebool:*)",
      "Bash(mokutil:*)",
      "Bash(sbctl:*)",
      "Bash(systemctl:*)",
      "Bash(virsh:*)",
      "Edit(Containerfile)",
      "Edit(kargs.d/**)",
      "Edit(etc/**)",
      "Edit(.github/workflows/**)",
      "Edit(automation/lib/**)"
    ]
  },
  "_comment": "System Code project settings for MiOS. This file is checked into the repo so every dev who opens the project inherits the same tool permissions. User-specific overrides go in .ai/foundation/settings.local.json (which is gitignored).",
  "_notes": [
    "Permissions follow the INDEX.md §4 deliverable contract: System Code may freely inspect the repo but must ask before mutating anything that lands in a build artifact or a signed image.",
    "The deny list covers the files INDEX.md says must not be touched without explicit human review: VERSION, CHANGELOG.md, specs/PACKAGES.md, the historical audit log, and signing/artifact workflows.",
    "Slash commands live in .ai/foundation/commands/. Sub-agents live in .ai/foundation/agents/. Both are checked in so the whole team (currently: Kabu) gets the same workflow."
  ]
}
