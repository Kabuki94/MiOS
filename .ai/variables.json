      "merge_rules": {
        "usr/": "Merge into /usr/ (add new files, preserve existing)",
        "etc/": "Merge into /etc/ (templates only, user configs untouched)",
        "var/": "Merge into /var/ (create missing dirs via tmpfiles.d)",
        "home/": "Merge into /home/ (skeleton files)"
      },
      "conflict_resolution": "Preserve deployed environment files",
      "script": "tools/mios-init.sh deploy"
    },

    "step_4_user_variable_ignition": {
      "action": "User sets ignitable variables",
      "method": "Edit ~/.config/mios/*.toml files",
      "variables": [
        "MIOS_BASE_IMAGE",
        "MIOS_IMAGE_NAME",
        "MIOS_USER",
        "MIOS_PASSWORD_HASH",
        "MIOS_FLATPAKS"
      ],
      "script": "tools/init-user-space.sh"
    },

    "step_5_build_ignition": {
      "action": "Build MiOS OCI image with user variables",
      "command": "just build",
      "variables_propagated": "All user_ignitable variables",
      "output": "localhost/mios:latest"
    }
  },

  "bootc_oci_compatibility": {
    "description": "Variables in context of bootc and OCI standards",

    "build_args": {
      "description": "Containerfile ARG variables (build-time only)",
      "scope": "Build stage",
      "persistence": "Not in final image",
      "examples": [
        "BASE_IMAGE",
        "MIOS_USER",
        "MIOS_PASSWORD_HASH"
      ]
    },

    "env_vars": {
      "description": "Containerfile ENV variables (runtime)",
      "scope": "Runtime",
      "persistence": "Baked into image layers",
      "examples": [
        "PATH",
        "MIOS_VERSION"
      ],
      "note": "Avoid for secrets or deployment-specific values"
    },

    "runtime_config": {
      "description": "Files in /etc/ and /var/ for runtime configuration",
      "scope": "Deployment",
      "persistence": "Persistent across updates",
      "examples": [
        "/etc/mios/runtime.env",
        "/var/lib/mios/state/*"
      ],
      "bootc_behavior": "Preserved during bootc upgrade"
    }
  },

