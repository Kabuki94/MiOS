{
  "schema_version": "1.0.0",
  "description": "MiOS variable tracking and metadata system - OpenAI/FOSS AI compatible",
  "variable_taxonomy": {
    "build_time": "Variables set during OCI image build (immutable in final image)",
    "runtime": "Variables set when deploying/running the image (mutable)",
    "user_ignitable": "Variables user can set before/during build ignition",
    "tracked": "Variables with @track: markers for automatic propagation"
  },

  "user_ignitable_variables": {
    "description": "User-editable variables that control build and deployment",
    "mutability": "transient",
    "storage": "~/.config/mios/*.toml (XDG-compliant)",

    "image_selection": {
      "MIOS_BASE_IMAGE": {
        "default": "ghcr.io/ublue-os/ucore-hci:stable-nvidia",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Containerfile:19",
          "Justfile:45"
        ],
        "marker": "@track:IMG_BASE",
        "description": "Base OCI image for MiOS build",
        "user_editable": true,
        "validation": "^[a-z0-9.-]+/[a-z0-9.-]+:[a-z0-9.-]+$",
        "alternatives": [
          "ghcr.io/ublue-os/ucore-hci:stable",
          "ghcr.io/ublue-os/ucore:stable",
          "registry.fedoraproject.org/fedora-bootc:rawhide"
        ]
      },

      "MIOS_IMAGE_NAME": {
        "default": "ghcr.io/kabuki94/mios",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Justfile:9",
          "config/registry.toml"
        ],
        "marker": "@track:REGISTRY_DEFAULT",
        "description": "Output image registry and name",
        "user_editable": true,
        "validation": "^[a-z0-9.-]+/[a-z0-9.-]+$"
      },

      "MIOS_BIB_IMAGE": {
        "default": "quay.io/centos-bootc/bootc-image-builder:latest",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Justfile:14"
        ],
        "marker": "@track:IMG_BIB",
        "description": "bootc-image-builder container image",
        "user_editable": true,
        "validation": "^[a-z0-9.-]+/[a-z0-9.-]+:[a-z0-9.-]+$"
      }
    },

    "user_provisioning": {
      "MIOS_USER": {
        "default": "mios",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Containerfile:55",
          "automation/31-user.sh"
        ],
        "description": "Default username for MiOS",
        "user_editable": true,
        "validation": "^[a-z_][a-z0-9_-]{0,31}$",
        "security": "low"
      },

      "MIOS_PASSWORD_HASH": {
        "default": "",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Containerfile:56",
          "automation/31-user.sh"
        ],
        "description": "SHA-512 password hash for user",
        "user_editable": true,
        "validation": "^\\$6\\$.+",
        "security": "critical",
        "placeholder": "INJ_PASSWORD_HASH",
        "generation": "python3 -c 'import crypt; print(crypt.crypt(\"password\", crypt.mksalt(crypt.METHOD_SHA512)))'"
      },

      "MIOS_HOSTNAME": {
        "default": "mios",
        "type": "string",
        "mutability": "runtime",
        "tracked_in": [
          "Containerfile:57",
          "automation/32-hostname.sh"
        ],
        "description": "System hostname",
        "user_editable": true,
        "validation": "^[a-z0-9-]{1,63}$",
        "runtime_override": "hostnamectl set-hostname <name>"
      }
    },

    "package_selection": {
      "MIOS_FLATPAKS": {
        "default": "",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Containerfile:58",
          "Containerfile:64-66",
          "Justfile:46",
          "usr/libexec/mios-flatpak-install.sh"
        ],
        "description": "Comma-separated list of Flatpak app IDs to pre-install",
        "user_editable": true,
        "format": "comma_separated",
        "examples": [
          "org.mozilla.firefox,org.gnome.Calendar",
          "com.visualstudio.code,io.podman_desktop.PodmanDesktop"
        ],
        "runtime_addition": "flatpak install -y <app-id>"
      }
    },

    "ai_configuration": {
      "MIOS_AI_KEY": {
        "default": "",
        "type": "string",
        "mutability": "runtime",
        "tracked_in": [
          ".ai/context.json",
          "specs/ai-integration/2026-04-27-Artifact-AI-006-Unified-Redirects.md"
        ],
        "description": "API key for AI services",
        "user_editable": true,
        "security": "critical",
        "storage": "~/.config/mios/ai.env (not committed)"
      },

      "MIOS_AI_MODEL": {
        "default": "llama3.1:8b",
        "type": "string",
        "mutability": "runtime",
        "tracked_in": [
          ".ai/context.json",
          ".ai/rag-config.yaml"
        ],
        "description": "AI model to use (Ollama, OpenAI, etc.)",
        "user_editable": true,
        "examples": [
          "llama3.1:8b",
          "gpt-4",
          "claude-3-opus"
        ]
      },

      "MIOS_AI_ENDPOINT": {
        "default": "http://localhost:8080/v1",
        "type": "string",
        "mutability": "runtime",
        "tracked_in": [
          ".ai/context.json",
          ".ai/rag-config.yaml"
        ],
        "description": "AI API endpoint URL",
        "user_editable": true,
        "validation": "^https?://[a-z0-9.-]+(:[0-9]+)?(/.*)?$"
      }
    },

    "build_configuration": {
      "MIOS_VAR_VERSION": {
        "default": "0.1.3",
        "type": "string",
        "mutability": "build_time",
        "tracked_in": [
          "Justfile:11",
          "VERSION"
        ],
        "marker": "@track:VAR_VERSION",
        "description": "MiOS version number",
        "user_editable": false,
        "managed_by": "push-to-github.ps1"
      }
    }
  },

  "build_stage_variables": {
    "description": "Variables that change behavior at different build stages",

    "stages": {
      "pre_build": {
        "description": "Before podman build starts",
        "variables": [
          "MIOS_BASE_IMAGE",
          "MIOS_IMAGE_NAME",
          "MIOS_USER",
          "MIOS_PASSWORD_HASH",
          "MIOS_HOSTNAME",
          "MIOS_FLATPAKS"
        ],
        "source": "~/.config/mios/*.toml",
        "propagation": "Containerfile ARG"
      },

      "build_time": {
        "description": "During OCI image build",
        "variables": [
          "PACKAGES_MD",
          "VERSION",
          "MIOS_BUILD_STATE"
        ],
        "source": "Containerfile COPY, automation/build.sh",
        "propagation": "Layer commits"
      },

      "post_build": {
        "description": "After image is built, before deployment",
        "variables": [
          "IMAGE_TAG",
          "RECHUNK_LAYERS"
        ],
        "source": "Justfile targets",
        "propagation": "podman commands"
      },

      "deployment": {
        "description": "When deploying to bare metal/VM/WSL2",
        "variables": [
          "MIOS_HOSTNAME",
          "MIOS_AI_KEY",
          "MIOS_AI_MODEL",
          "MIOS_AI_ENDPOINT"
        ],
        "source": "/etc/mios/runtime.env, systemd EnvironmentFile",
        "propagation": "systemd units, shell profiles"
      },

      "runtime": {
        "description": "After system is booted and running",
        "variables": [
          "MIOS_AI_*",
          "MIOS_ROLE",
          "GPU_VENDOR"
        ],
        "source": "~/.config/mios/runtime.env, /var/lib/mios/state/",
        "propagation": "Environment variables, systemd-detect-virt"
      }
    }
  },

  "variable_storage_fhs": {
    "description": "Linux FHS-compliant variable storage locations",

    "build_time_immutable": {
      "path": "/usr/share/mios/",
      "files": {
        "PACKAGES.md": "Package SSOT",
        "VERSION": "MiOS version",
        "defaults.env": "Default variable values"
      },
      "mutability": "immutable",
      "layer": "OCI image"
    },

    "system_configuration": {
      "path": "/etc/mios/",
      "files": {
        "runtime.env": "System-wide runtime variables",
        "ignition.toml": "Build ignition configuration"
      },
      "mutability": "admin_editable",
      "layer": "Config overlay"
    },

    "user_configuration": {
      "path": "~/.config/mios/",
      "files": {
        "env.toml": "User environment variables",
        "images.toml": "User image selections",
        "build.toml": "User build preferences",
        "flatpaks.list": "User Flatpak list",
        "ai.env": "User AI configuration (not committed)"
      },
      "mutability": "user_editable",
      "layer": "XDG Base Directory"
    },

    "state_data": {
      "path": "/var/lib/mios/",
      "files": {
        "state/role": "Detected system role (desktop/k3s/ha)",
        "state/gpu": "Detected GPU vendor",
        "state/platform": "systemd-detect-virt output",
        "memory/journal/v1.jsonl": "Episodic memory"
      },
      "mutability": "system_managed",
      "layer": "Persistent state"
    },

    "cache_data": {
      "path": "/var/cache/mios/",
      "files": {
        "build-cache/": "Build artifact cache",
        "embeddings/": "AI embedding cache"
      },
      "mutability": "system_managed",
      "layer": "Ephemeral cache"
    }
  },

  "variable_propagation": {
    "description": "How variables flow through the build and deployment pipeline",

    "build_entry_points": {
      "justfile": {
        "variables_read": [
          "MIOS_BASE_IMAGE",
          "MIOS_IMAGE_NAME",
          "MIOS_BIB_IMAGE",
          "MIOS_FLATPAKS"
        ],
        "source": "env_var_or_default() + tools/load-user-env.sh",
        "propagation": "podman build --build-arg"
      },

      "mios_build_local_ps1": {
        "variables_read": [
          "All user ignitable variables"
        ],
        "source": "$env:MIOS_* or .env.mios",
        "propagation": "podman build --build-arg"
      },

      "containerfile": {
        "variables_read": [
          "MIOS_USER",
          "MIOS_PASSWORD_HASH",
          "MIOS_HOSTNAME",
          "MIOS_FLATPAKS"
        ],
        "source": "ARG directives",
        "propagation": "ENV (for runtime vars) or RUN (for build-time)"
      }
    },

    "runtime_propagation": {
      "systemd_units": {
        "method": "EnvironmentFile=/etc/mios/runtime.env",
        "variables": [
          "MIOS_AI_*",
          "MIOS_ROLE"
        ]
      },

      "shell_profiles": {
        "method": "source /usr/lib/profile.d/mios-env.sh",
        "variables": [
          "MIOS_AI_*",
          "PATH additions"
        ]
      },

      "quadlet_containers": {
        "method": "Environment= directives in .container files",
        "variables": [
          "POSTGRES_PASSWORD",
          "OLLAMA_MODELS"
        ]
      }
    }
  },

  "ignition_workflow": {
    "description": "Fedora Server deployment with merge-only overlay",

    "step_1_fedora_server_base": {
      "action": "Install Fedora Server (minimal)",
      "variables": [],
      "filesystem": "Clean Fedora Server FHS structure"
    },

    "step_2_dependency_installation": {
      "action": "Install build environment packages",
      "script": "install.sh",
      "packages": [
        "podman",
        "buildah",
        "just",
        "git"
      ],
      "install_location": "System directories (/usr/bin, /usr/lib)",
      "merge_behavior": "Flat installation (no overwrites, package manager handles)"
    },

    "step_3_mios_overlay_merge": {
      "action": "Overlay MiOS structure (MERGE ONLY, NO OVERWRITES)",
      "source": "mios/ repository",
