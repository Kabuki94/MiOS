#!/bin/bash
# MiOS GNOME Remote Desktop first-boot setup.
# Referenced by mios-grd-setup.service; bakes a self-signed TLS cert for
# headless RDP, opens the firewall port, and flips GRD on via grdctl --system.
# Supports pre-seeded credentials via MIOS_PASSWORD env var or
# /etc/mios/grd/credentials file (user:pass).
set -euo pipefail

SENTINEL="/var/lib/mios/.grd-init-done"
STATE_DIR="/var/lib/gnome-remote-desktop"
CERT="${STATE_DIR}/rdp-tls.crt"
KEY="${STATE_DIR}/rdp-tls.key"
LOG="/var/log/mios-grd-setup.log"

log() { printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" | tee -a "$LOG"; }

mkdir -p "$(dirname "$SENTINEL")" "$STATE_DIR"

if [ -f "$SENTINEL" ]; then
    log "GRD already initialized; nothing to do."
    exit 0
fi

if ! command -v grdctl >/dev/null 2>&1; then
    log "grdctl not found — gnome-remote-desktop is not installed; skipping."
    exit 0
fi

if [ ! -s "$CERT" ] || [ ! -s "$KEY" ]; then
    log "Generating self-signed TLS material for GRD (EC prime256v1)..."
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -sha256 -days 3650 -nodes \
        -keyout "$KEY" -out "$CERT" \
        -subj "/CN=MiOS-RDP" >>"$LOG" 2>&1
    chown -R gnome-remote-desktop:gnome-remote-desktop "$STATE_DIR" 2>/dev/null || true
    chmod 600 "$KEY"
    chmod 0644 "$CERT"
fi

log "Binding TLS cert/key to GRD system daemon..."
grdctl --system rdp set-tls-cert "$CERT" >>"$LOG" 2>&1 || log "warn: set-tls-cert failed"
grdctl --system rdp set-tls-key  "$KEY"  >>"$LOG" 2>&1 || log "warn: set-tls-key failed"

log "Configuring RDP transports (TCP + VSOCK)..."
grdctl --system rdp set-transport both >>"$LOG" 2>&1 || log "warn: set-transport failed"

# 1. Check for env-var credentials (passed via systemd EnvironmentFile or similar)
if [[ -n "${MIOS_PASSWORD:-}" ]]; then
    log "Applying RDP credentials from environment..."
    grdctl --system rdp set-credentials mios "$MIOS_PASSWORD" >>"$LOG" 2>&1 \
        || log "warn: set-credentials failed"
fi

# 2. Optional pre-seeded credentials at /etc/mios/grd/credentials (user:pass).
# This takes precedence over the default env var if present.
CRED_FILE="/etc/mios/grd/credentials"
if [ -s "$CRED_FILE" ]; then
    USER_NAME="$(cut -d: -f1 "$CRED_FILE")"
    USER_PASS="$(cut -d: -f2- "$CRED_FILE")"
    if [ -n "$USER_NAME" ] && [ -n "$USER_PASS" ]; then
        log "Applying pre-seeded RDP credentials from file for user '${USER_NAME}'..."
        grdctl --system rdp set-credentials "$USER_NAME" "$USER_PASS" >>"$LOG" 2>&1 \
            || log "warn: set-credentials failed"
    fi
    # Scrub the cleartext credentials file once applied.
    shred -u "$CRED_FILE" 2>/dev/null || rm -f "$CRED_FILE"
fi

# 3. Only enable if we actually have a password set, or it remains dormant for security
if grdctl --system rdp set-credentials mios "" 2>/dev/null | grep -q "mios"; then
     log "Enabling GRD RDP..."
     grdctl --system rdp enable >>"$LOG" 2>&1 || log "warn: rdp enable failed"
     systemctl enable --now gnome-remote-desktop.service 2>/dev/null || true
else
     log "INFO: No RDP credentials set. Service remains disabled until configured manually."
fi

if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state >/dev/null 2>&1; then
    log "Configuring firewalld ports (3389/tcp, 8080/tcp)..."
    firewall-cmd --add-port=3389/tcp --add-port=8080/tcp >>"$LOG" 2>&1 || true
    firewall-cmd --permanent --add-port=3389/tcp --add-port=8080/tcp >>"$LOG" 2>&1 || true
fi

touch "$SENTINEL"
log "GRD first-boot setup complete."
