#!/bin/bash
set -euo pipefail
BACKUP_DIR="/var/lib/mios/backups"
TS=$(date +%Y%m%d-%H%M%S)
mkdir -p "$BACKUP_DIR"
echo "MiOS — Backing up system state..."
tar czf "$BACKUP_DIR/etc-${TS}.tar.gz" /etc/ 2>/dev/null || true
tar czf "$BACKUP_DIR/home-${TS}.tar.gz" /var/home/ 2>/dev/null || true
tar czf "$BACKUP_DIR/virt-${TS}.tar.gz" /var/lib/libvirt/ /var/lib/rancher/ 2>/dev/null || true
# Backup Podman metadata (SQLite DB) without backing up monolithic image layers
tar czf "$BACKUP_DIR/podman-meta-${TS}.tar.gz" /var/lib/containers/storage/libpod/ 2>/dev/null || true
echo "Backups saved to $BACKUP_DIR/"
ls -lh "$BACKUP_DIR/"*"${TS}"*
