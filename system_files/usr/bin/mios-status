#!/bin/bash
set -euo pipefail

JSON_MODE=false
for arg in "$@"; do
    if [[ "$arg" == "--json" ]]; then JSON_MODE=true; fi
done

if [[ "$JSON_MODE" == "true" ]]; then
    # Build a clean JSON object
    SERVICES=()
    for svc in gdm cockpit.socket sshd libvirtd.socket virtnetworkd.socket virtqemud.socket \
               firewalld tuned k3s gnome-remote-desktop avahi-daemon; do
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            SERVICES+=("\"$svc\": \"active\"")
        elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
            SERVICES+=("\"$svc\": \"enabled\"")
        fi
    done

    # Join services into JSON string
    SVCS_JSON=$(IFS=,; echo "${SERVICES[*]}")

    printf '{"hostname": "%s", "uptime": "%s", "kernel": "%s", "services": {%s}}\n' \
        "$(hostname)" \
        "$(uptime -p 2>/dev/null || uptime)" \
        "$(uname -r)" \
        "$SVCS_JSON"
    exit 0
fi

echo "MiOS v2.1.0 — System Status"
echo "════════════════════════════════"
echo ""
echo "Hostname:  $(hostname)"
echo "Uptime:    $(uptime -p 2>/dev/null || uptime)"
echo "Kernel:    $(uname -r)"
echo "bootc:     $(bootc status 2>/dev/null | head -3 || echo 'N/A')"
echo ""
echo "Services:"
for svc in gdm cockpit.socket sshd libvirtd.socket virtnetworkd.socket virtqemud.socket \
           firewalld tuned k3s gnome-remote-desktop avahi-daemon; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        printf "  ✓ %-30s active\n" "$svc"
    elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
        printf "  ○ %-30s enabled (inactive)\n" "$svc"
    fi
done
echo ""
echo "Podman:"
podman system df 2>/dev/null || echo "  Not available"
