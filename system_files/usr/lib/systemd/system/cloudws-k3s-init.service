[Unit]
Description=CloudWS K3s Manifest Seeder
Before=k3s.service
ConditionPathExists=/usr/share/cloudws/k3s-manifests

[Service]
Type=oneshot
RemainAfterExit=yes

# Create the persistent directory if it doesn't exist
ExecStartPre=/bin/mkdir -p /var/lib/rancher/k3s/server/manifests

# Copy the immutable manifests into the persistent datastore
ExecStart=/bin/bash -c "cp -a /usr/share/cloudws/k3s-manifests/*.yaml /var/lib/rancher/k3s/server/manifests/ 2>/dev/null || true"
ExecStartPost=/bin/chmod 0600 /var/lib/rancher/k3s/server/manifests/*.yaml

[Install]
WantedBy=multi-user.target
