# CloudWS Systemd Presets
# This file declaratively sets the default enablement state for services.

# --- WSL2 Fallback & Initialization ---
enable cloudws-wsl-firstboot.service
enable dbus-daemon-wsl.service

# --- CloudWS Custom Services ---
enable cloudws-cdi-detect.service
enable cloudws-libvirtd-setup.service
enable cloudws-crowdsec-init.service

# --- Core Infrastructure & Sockets ---
enable sshd.service
enable podman.socket
enable cockpit.socket
enable libvirtd.socket

# --- Updates & Health (uupd replaces standard bootc updates) ---
enable uupd.timer
enable greenboot-healthcheck.service
disable bootc-fetch-apply-updates.timer
disable rpm-ostreed-automatic.timer
disable systemd-remount-fs.service
