#!/usr/bin/env bash
# CloudWS TPM 2.0 LUKS Enrollment Tool
# Binds disk encryption to TPM 2.0 PCRs 7 (Secure Boot) and 11 (UKI measurement).
set -euo pipefail

C=$'\033[0;36m'; W=$'\033[1;37m'; G=$'\033[0;32m'; Y=$'\033[0;33m'; R=$'\033[0;31m'; N=$'\033[0m'
log() { printf "  ${C}TPM-ENROLL:${N} %s\n" "$*"; }
fail() { printf "  ${R}ERROR:${N} %s\n" "$*"; exit 1; }

echo "${W}═══ CloudWS TPM 2.0 LUKS Enrollment ═══${N}"

if [[ $EUID -ne 0 ]]; then
   fail "This script must be run as root."
fi

# 1. Detect TPM 2.0
if [[ ! -c /dev/tpmrm0 ]]; then
    fail "TPM 2.0 device (/dev/tpmrm0) not found. Is TPM enabled in BIOS?"
fi

# 2. Identify Root LUKS Device
ROOT_DEV=$(lsblk -no PKNAME $(findmnt -no SOURCE /) 2>/dev/null || echo "")
if [[ -z "$ROOT_DEV" ]]; then
    # Fallback for complex layouts
    ROOT_DEV=$(lsblk -no PKNAME /dev/mapper/root 2>/dev/null || echo "")
fi

if [[ -z "$ROOT_DEV" ]]; then
    log "Could not identify root block device. Attempting to scan for LUKS containers..."
    LUKS_DEVS=$(lsblk -lnp -o NAME,FSTYPE | grep crypto_LUKS | awk '{print $1}')
    if [[ -z "$LUKS_DEVS" ]]; then
        fail "No LUKS encrypted devices detected. TPM enrollment skipped."
    fi
    ROOT_DEV=$(echo "$LUKS_DEVS" | head -n1)
fi

log "Detected encrypted device: ${W}$ROOT_DEV${N}"

# 3. Check for systemd-cryptenroll
if ! command -v systemd-cryptenroll &>/dev/null; then
    fail "systemd-cryptenroll not found. Ensure 'systemd-udev' is installed."
fi

# 4. Enroll TPM2
log "Enrolling TPM 2.0 (PCR 7,11) for passwordless boot..."
# PCR 7: Secure Boot Policy
# PCR 11: UKI / Unified Kernel Image measurement
if systemd-cryptenroll --tpm2-device=auto --tpm2-pcrs=7,11 "$ROOT_DEV"; then
    echo ""
    printf "  ${G}SUCCESS:${N} LUKS device ${W}$ROOT_DEV${N} bound to TPM 2.0\n"
    echo "  Your system will now unlock automatically if Secure Boot and UKI are intact."
    echo ""
else
    fail "Failed to enroll TPM2. Check 'journalctl -xe' for details."
fi
