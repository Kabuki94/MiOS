#!/usr/bin/bash
# cloudws role-apply: reads /etc/cloudws/role.conf (or kernel cmdline), enables
# role-specific services, and sets the default systemd target accordingly.
# Unified image, per-boot role selection.
set -euo pipefail

ROLE_CONF=/etc/cloudws/role.conf
STATE_DIR=/var/lib/cloudws
mkdir -p "$STATE_DIR"

log() { printf '[cloudws-role] %s\n' "$*"; }

# ----------------------------------------------------------------------------
# 1. Determine role (cmdline wins over role.conf; default = desktop)
# ----------------------------------------------------------------------------
ROLE=""
PROFILE=""
FEATURES=""

if [[ -r /proc/cmdline ]]; then
    for tok in $(< /proc/cmdline); do
        case "$tok" in
            cloudws.role=*)     ROLE="${tok#cloudws.role=}" ;;
            cloudws.profile=*)  PROFILE="${tok#cloudws.profile=}" ;;
            cloudws.features=*) FEATURES="${tok#cloudws.features=}" ;;
        esac
    done
fi

if [[ -z "$ROLE" && -r "$ROLE_CONF" ]]; then
    # shellcheck disable=SC1090
    . "$ROLE_CONF"
fi

# WSL auto-headless unless explicitly overridden
VIRT=$(systemd-detect-virt 2>/dev/null || echo "none")
if [[ -z "$ROLE" ]] && [[ "$VIRT" == "wsl" || -e /dev/dxg ]]; then
    ROLE="headless"
    log "WSL detected - defaulting to headless role"
fi

# No GPU + no graphics session inherited -> headless (Hyper-V gen2, cloud VMs)
if [[ -z "$ROLE" ]] && ! compgen -G "/dev/dri/renderD*" >/dev/null; then
    # Also no GNOME session file selection hint
    if [[ ! -e /sys/class/drm/card0 ]]; then
        ROLE="headless"
        log "No DRM device - defaulting to headless role"
    fi
fi

ROLE="${ROLE:-desktop}"
PROFILE="${PROFILE:-workstation}"
FEATURES="${FEATURES:-}"

log "resolved role=$ROLE profile=$PROFILE features=$FEATURES"

# Record resolution
cat > "$STATE_DIR/role.active" <<EOF
ROLE=$ROLE
PROFILE=$PROFILE
FEATURES=$FEATURES
APPLIED=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF

# ----------------------------------------------------------------------------
# 2. Service set per role (enable + disable)
# ----------------------------------------------------------------------------
enable_units() {
    for u in "$@"; do
        systemctl enable --now "$u" 2>/dev/null || systemctl enable "$u" 2>/dev/null || true
    done
}
disable_units() {
    for u in "$@"; do
        systemctl disable --now "$u" 2>/dev/null || true
    done
}

case "$ROLE" in
    desktop)
        enable_units gdm.service libvirtd.service libvirtd.socket virtnetworkd.service \
                     virtqemud.service virtstoraged.service virtnodedevd.service
        disable_units k3s.service k3s-agent.service corosync.service pacemaker.service
        systemctl set-default cloudws-desktop.target
        ;;
    k3s-master)
        enable_units k3s.service
        disable_units gdm.service k3s-agent.service corosync.service pacemaker.service
        systemctl set-default cloudws-k3s-master.target
        ;;
    k3s-worker)
        enable_units k3s-agent.service
        disable_units gdm.service k3s.service corosync.service pacemaker.service
        systemctl set-default cloudws-k3s-worker.target
        ;;
    ha-node)
        enable_units corosync.service pacemaker.service
        # ceph-mon/osd enabled only if /etc/cloudws/ceph-role is set (handled below)
        disable_units gdm.service k3s.service k3s-agent.service
        systemctl set-default cloudws-ha-node.target
        ;;
    hybrid)
        enable_units gdm.service libvirtd.service k3s-agent.service
        disable_units k3s.service corosync.service pacemaker.service
        systemctl set-default cloudws-hybrid.target
        ;;
    headless)
        disable_units gdm.service libvirtd.service k3s.service k3s-agent.service \
                      corosync.service pacemaker.service
        # sshd + podman.socket + uupd already enabled by preset
        systemctl set-default cloudws-headless.target
        ;;
    *)
        log "WARN: unknown role '$ROLE' - falling back to headless"
        systemctl set-default cloudws-headless.target
        ;;
esac

# ----------------------------------------------------------------------------
# 3. Feature gates (comma-separated list)
# ----------------------------------------------------------------------------
IFS=',' read -r -a FEAT_ARR <<< "$FEATURES"
for f in "${FEAT_ARR[@]}"; do
    case "$f" in
        ceph-mon)    systemctl enable 'ceph-mon@'"$(hostname -s)"'.service' 2>/dev/null || true ;;
        ceph-osd)    : "# ceph-osd@N enabled via ceph-volume activate, not here" ;;
        gamescope)   systemctl enable gamescope-session.target 2>/dev/null || true ;;
        lookingglass): "# kvmfr loaded via modprobe.d; no unit to enable" ;;
        waydroid)    systemctl enable waydroid-container.service 2>/dev/null || true ;;
        nocloud-init) systemctl disable cloud-init.service cloud-final.service 2>/dev/null || true ;;
    esac
done

log "role apply complete; default target now $(systemctl get-default)"