#!/usr/bin/bash
# libvirtd first-boot: restorecon state, default network, storage pool
set -euo pipefail

log() { printf '[cloudws-libvirtd] %s\n' "$*"; }

# SELinux restore on mutable libvirt state
if command -v restorecon >/dev/null 2>&1; then
    restorecon -R /var/lib/libvirt 2>/dev/null || true
fi

# Default network
if virsh net-list --all 2>/dev/null | grep -q default; then
    virsh net-autostart default 2>/dev/null || true
    virsh net-start default     2>/dev/null || true
fi

log "libvirtd first-boot complete"