#!/usr/bin/env bash
# CloudWS-OS Universal SR-IOV Initialization Script
# This script initializes SR-IOV Virtual Functions (VFs) for detected PFs.
# In production, specific VF counts should be set via kernel command line
# or a drop-in configuration file for this service.

set -euo pipefail

echo "==> [CloudWS] Scanning for SR-IOV capable Physical Functions (PFs)..."

# Default to 0 unless specified. In a real environment, users would use
# something like `cloudws_sriov_vfs=4` as a kernel argument.
# For now, we provide the mechanism for persistence.
DEFAULT_VFS=0

# Check for kernel parameter override: cloudws.sriov_vfs=X
KERNEL_VAL=$(grep -oP '(?<=cloudws.sriov_vfs=)\d+' /proc/cmdline || echo "")
VF_COUNT=${KERNEL_VAL:-$DEFAULT_VFS}

for PF_DIR in /sys/class/net/*/device; do
    if [ -f "${PF_DIR}/sriov_numvfs" ]; then
        IFACE=$(basename "$(dirname "${PF_DIR}")")
        TOTAL_VFS=$(cat "${PF_DIR}/sriov_totalvfs")
        
        if [ "$VF_COUNT" -gt "$TOTAL_VFS" ]; then
            echo "  [!] WARNING: Requested VF count ($VF_COUNT) exceeds max ($TOTAL_VFS) for $IFACE. Capping at max."
            VF_COUNT=$TOTAL_VFS
        fi

        echo "  [+] Initializing $VF_COUNT VFs on $IFACE (Driver: $(basename "$(readlink "${PF_DIR}/driver")"))..."
        
        # Reset to 0 first to be safe, then apply.
        echo 0 > "${PF_DIR}/sriov_numvfs" || true
        echo "$VF_COUNT" > "${PF_DIR}/sriov_numvfs" || {
            echo "  [!] ERROR: Failed to initialize VFs on $IFACE. Driver may be busy or unsupported."
        }
    fi
done

echo "==> [CloudWS] SR-IOV Initialization complete."
