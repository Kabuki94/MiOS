#!/usr/bin/env bash
set -euo pipefail

echo "Starting CloudWS WSL2 first-boot initialization..."

# Ensure base directories exist
mkdir -p /var/home /var/lib/cloudws

# Restore 'cloudws' user home
if [ ! -d /var/home/cloudws ]; then
    echo "Restoring /var/home/cloudws from /etc/skel..."
    cp -aT /etc/skel /var/home/cloudws
    chown -R cloudws:cloudws /var/home/cloudws
    chmod 700 /var/home/cloudws
fi

# Restore 'core' user home (required for Podman Desktop / Docker Desktop interop)
if id "core" &>/dev/null; then
    if [ ! -d /var/home/core ]; then
        echo "Restoring /var/home/core from /etc/skel..."
        cp -aT /etc/skel /var/home/core
        chown -R core:core /var/home/core
        chmod 700 /var/home/core
    fi
fi

# Start required interoperability services for WSL2 to host communication
echo "Starting podman.socket and sshd for Windows host interop..."
systemctl start podman.socket sshd.service || true

# Mark as completed so this only runs once
touch /var/lib/cloudws/.wsl-firstboot-done

echo "WSL2 first-boot initialization complete."
exit 0
