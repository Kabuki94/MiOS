#!/bin/bash
set -euo pipefail
SENTINEL="/var/lib/cloudws/.grd-init-done"
[ -f "$SENTINEL" ] && exit 0
GRD_DIR="/var/lib/gnome-remote-desktop"
mkdir -p "$GRD_DIR"
if [ ! -f "$GRD_DIR/rdp-tls.key" ]; then
    openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 -sha256 -days 3650 -nodes -keyout "$GRD_DIR/rdp-tls.key" -out "$GRD_DIR/rdp-tls.crt" -subj "/CN=CloudWS-RDP" 2>/dev/null
    chown -R gnome-remote-desktop:gnome-remote-desktop "$GRD_DIR" 2>/dev/null || true
    chmod 600 "$GRD_DIR/rdp-tls.key"
fi
grdctl --system rdp set-tls-key "$GRD_DIR/rdp-tls.key" 2>/dev/null || true
grdctl --system rdp set-tls-cert "$GRD_DIR/rdp-tls.crt" 2>/dev/null || true

# Security Finding #2: Do not bake default credentials into image
# Check for build-time injected password or local secret
if [[ -n "${CLOUDWS_PASSWORD:-}" ]]; then
    grdctl --system rdp set-credentials cloudws "$CLOUDWS_PASSWORD" 2>/dev/null || true
    grdctl --system rdp enable 2>/dev/null || true
    systemctl enable --now gnome-remote-desktop.service 2>/dev/null || true
else
    echo "WARN: No RDP credentials provided. Service remains disabled for security."
fi
if command -v firewall-cmd &>/dev/null && firewall-cmd --state &>/dev/null 2>&1; then
    # Apply runtime and permanent rules independently to avoid `--reload` flushing nftables
    firewall-cmd --add-port=3389/tcp --add-port=8080/tcp 2>/dev/null || true
    firewall-cmd --permanent --add-port=3389/tcp --add-port=8080/tcp 2>/dev/null || true
fi
mkdir -p "$(dirname "$SENTINEL")"
touch "$SENTINEL"
