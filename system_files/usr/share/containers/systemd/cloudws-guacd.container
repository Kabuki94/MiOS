[Unit]
Description=CloudWS Guacamole Protocol Proxy (guacd)
After=network-online.target
Wants=network-online.target
[Container]
Image=docker.io/guacamole/guacd:latest
ContainerName=cloudws-guacd
Network=host
HttpProxy=false
AutoUpdate=registry
[Service]
Restart=on-failure
RestartSec=30
[Install]
WantedBy=multi-user.target
