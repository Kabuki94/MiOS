[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='blue'
font-name='Geist 11'
document-font-name='Geist 11'
monospace-font-name='Geist Mono 10'
cursor-theme='Bibata-Modern-Classic'
enable-animations=true

[org/gnome/desktop/wm/preferences]
titlebar-font='Geist Bold 11'

[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'org.gnome.Ptyxis.desktop', 'org.gnome.Epiphany.desktop', 'cloudws-cockpit.desktop', 'org.gnome.Software.desktop']
enabled-extensions=['appindicatorsupport@rgcjonas.gmail.com', 'dash-to-dock@micxgx.gmail.com']

[org/gnome/shell/extensions/dash-to-dock]
dock-position='BOTTOM'
dash-max-icon-size=48
show-trash=false
show-mounts=false

[org/gnome/desktop/app-folders]
folder-children=['Development', 'Gaming', 'System', 'Virtualization']

[org/gnome/desktop/app-folders/folders/Development]
name='Development'
apps=['com.vscodium.codium.desktop', 'org.gnome.TextEditor.desktop', 'org.gnome.Ptyxis.desktop']

[org/gnome/desktop/app-folders/folders/Gaming]
name='Gaming'
apps=['steam.desktop', 'net.lutris.Lutris.desktop', 'io.github.dosbox-staging.desktop', 'com.usebottles.bottles.desktop', 'gamemode-simulate-game.desktop']

[org/gnome/desktop/app-folders/folders/System]
name='System'
apps=['org.gnome.Settings.desktop', 'org.gnome.tweaks.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.SystemMonitor.desktop', 'org.gnome.Logs.desktop', 'org.gnome.baobab.desktop', 'com.mattjakeman.ExtensionManager.desktop', 'cloudws-cockpit.desktop', 'org.gnome.Software.desktop']

[org/gnome/desktop/app-folders/folders/Virtualization]
name='Virtualization'
apps=['virt-manager.desktop', 'io.podman_desktop.PodmanDesktop.desktop', 'org.gnome.Connections.desktop', 'waydroid.desktop', 'remote-viewer.desktop', 'org.gnome.Boxes.desktop']
