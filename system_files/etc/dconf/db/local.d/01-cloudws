apps=['wine-notepad.desktop', 'wine-winecfg.desktop', 'wine-regedit.desktop', 'wine-winefile.desktop', 'wine-uninstaller.desktop', 'wine-oleview.desktop', 'wine-wineboot.desktop', 'wine-wordpad.desktop', 'wine-winemine.desktop', 'winetricks.desktop']
