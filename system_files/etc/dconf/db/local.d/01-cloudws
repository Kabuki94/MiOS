[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='blue'
font-name='Geist 11'
document-font-name='Geist 11'
monospace-font-name='Geist Mono 10'
cursor-theme='Bibata-Modern-Classic'
cursor-size=24
enable-animations=true

[org/gnome/desktop/wm/preferences]
titlebar-font='Geist Bold 11'
button-layout='close,minimize:'

[org/gnome/shell]
favorite-apps=['org.gnome.Nautilus.desktop', 'org.gnome.Ptyxis.desktop', 'org.gnome.Epiphany.desktop', 'btop.desktop', 'cockpit.desktop', 'org.localsend.localsend_app.desktop', 'org.gnome.Software.desktop']
enabled-extensions=['appindicatorsupport@rgcjonas.gmail.com', 'dash-to-dock@micxgx.gmail.com']

[org/gnome/shell/extensions/dash-to-dock]
dock-position='BOTTOM'
dash-max-icon-size=48
show-trash=false
show-mounts=false

[org/gnome/desktop/app-folders]
folder-children=['Gaming', 'System', 'Virtualization', 'Wine']

[org/gnome/desktop/app-folders/folders/Gaming]
name='Gaming'
apps=['steam.desktop', 'net.lutris.Lutris.desktop', 'com.usebottles.bottles.desktop', 'dosbox-staging.desktop', 'io.github.dosbox-staging.desktop', 'protontricks.desktop', 'net.davidotek.pupgui2.desktop']

[org/gnome/desktop/app-folders/folders/System]
name='System'
apps=['org.gnome.Settings.desktop', 'cockpit.desktop', 'ceph-dashboard.desktop', 'org.gnome.Logs.desktop', 'com.mattjakeman.ExtensionManager.desktop', 'org.gnome.Software.desktop', 'btop.desktop', 'nvtop.desktop', 'org.gnome.DiskUtility.desktop', 'org.gnome.SystemMonitor.desktop', 'org.gnome.baobab.desktop', 'page.tesk.Refine.desktop', 'com.github.tchx84.Flatseal.desktop', 'lm_sensors.desktop', 'nm-connection-editor.desktop', 'org.gnome.Connections.desktop']

[org/gnome/desktop/app-folders/folders/Virtualization]
