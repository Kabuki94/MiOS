{\n  "name": "MiOS Dev Container",\n  "build": {\n    "dockerfile": "Dockerfile",\n    "context": ".."\n  },\n  "features": {\n    "ghcr.io/devcontainers/features/docker-in-docker": {},\n    "ghcr.io/devcontainers/features/docker-cli": {},\n    "ghcr.io/devcontainers/features/kubectl": {},\n    "ghcr.io/devcontainers/features/helm": {}\n  },\n  "customizations": {\n    "vscode": {\n      "extensions": [\n        "ms-azuretools.vscode-docker",\n        "ms-kubernetes-tools.vscode-kubernetes-tools",\n        "eamodio.gitlens",\n        "streetsidesoftware.code-spell-checker",\n        "ms-vscode.cpptools",\n        "ms-vscode.makefile-tools"\n      ],\n      "settings": {\n        "terminal.integrated.shell.linux": "/bin/bash"\n      }\n    }\n  },\n  "workspaceFolder": "/workspaces/MiOS",\n  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/MiOS,type=bind,consistency=cached",\n  "postCreateCommand": "bash .devcontainer/automation/setup.sh",\n  "forwardPorts": [],\n  "remoteUser": "vscode",\n  "containerEnv": {\n    "DEBIAN_FRONTEND": "noninteractive"\n  },\n  "mounts": [\n    "source=/dev/kvm,target=/dev/kvm,type=bind,consistency=delegated"\n  ],\n  "runArgs": [\n    "--privileged"\n  ],\n  "onCreateCommand": ""\n}