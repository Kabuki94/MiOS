# Base image optimized for VS Code devcontainers\nFROM mcr.microsoft.com/devcontainers/base:ubuntu\n\nARG DEBIAN_FRONTEND=noninteractive\n\n# Core tools used by this project (git, build tools, OCI tooling, QEMU)\nRUN apt-get update \\n  && apt-get install -y --no-install-recommends \\n    git curl ca-certificates gnupg lsb-release build-essential make \\n    apt-transport-https software-properties-common \\n    uidmap dbus-user-session fuse libcap2-bin \\n    qemu-user-static qemu-utils qemu-system-x86 \\n    podman buildah skopeo \
    docker.io docker-compose \
    just \
    jq python3 python3-pip openssh-client rsync \
  && rm -rf /var/lib/apt/lists/*\n\n# Ensure vscode user exists (image base normally provides it)\nARG USERNAME=vscode\nARG USER_UID=1000\nARG USER_GID=1000\n\nRUN if ! id -u ${USERNAME} >/dev/null 2>&1; then \\n      groupadd --gid ${USER_GID} ${USERNAME} || true && \\n      useradd -s /bin/bash --uid ${USER_UID} --gid ${USER_GID} -m ${USERNAME} || true; \\n    fi\n\n# Add kubeconfig dir for the user and ensure permission\nRUN mkdir -p /home/${USERNAME}/.kube && chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/.kube\n\nUSER ${USERNAME}\nWORKDIR /home/${USERNAME}\n\n# Keep Dockerfile small -- postCreateCommand handles some tool installs (kubectl/helm)\nENV PATH="/home/${USERNAME}/.local/bin:${PATH}"\n