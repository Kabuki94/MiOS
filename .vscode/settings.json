{
  "_comment": "VSCodium / VSCode workspace settings for CloudWS-bootc. WSL terminal profile removed — having it defined at all causes VSCodium to prefer it when extensions request 'a shell,' and Windows routes bare `bash` through WSL which spawns external popups. On a Windows 11 host, everything runs through PowerShell. Run shell tasks inside WSL manually with `wsl` if needed.",

  "files.associations": {
    "Containerfile": "dockerfile",
    "*.toml": "toml",
    "kargs.d/*.toml": "toml",
    "kargs.d/*": "toml",
    "*.ps1": "powershell",
    "Justfile": "makefile",
    "scripts/cloudws-*": "shellscript",
    "system_files/usr/libexec/cloudws/*": "shellscript",
    "system_files/usr/bin/gamescope-session-steam": "shellscript",
    "system_files/usr/local/bin/cloudws-ceph": "shellscript",
    "system_files/etc/greenboot/check/wanted.d/*": "shellscript"
  },

  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/build": true,
    "**/output": true,
    "**/*.qcow2": true,
    "**/*.vhdx": true,
    "**/*.iso": true,
    "**/*.raw": true
  },

  "search.exclude": {
    "**/.git": true,
    "**/build": true,
    "**/output": true,
    "**/*.qcow2": true,
    "**/*.vhdx": true,
    "**/*.iso": true,
    "**/*.raw": true,
    "docs/knowledge/blueprints/*.docx": true
  },

  "cSpell.words": [
    "adwaita",
    "anchore",
    "bibata",
    "bootc",
    "buildah",
    "buildx",
    "cloudws",
    "containerfile",
    "containerfiles",
    "creds",
    "crowdsec",
    "cyclonedx",
    "dbus",
    "dconf",
    "digestfile",
    "eobash",
    "eoenv",
    "eogtk",
    "fastfetch",
    "firstboot",
    "flathub",
    "flatpaks",
    "fulcio",
    "greenboot",
    "gschema",
    "healthcheck",
    "hostedtoolcache",
    "imagectl",
    "jlumbroso",
    "ldconfig",
    "libadwaita",
    "libexec",
    "libvirtd",
    "oneshot",
    "oras",
    "ostree",
    "ostreed",
    "pipefail",
    "rechunk",
    "rechunked",
    "rechunking",
    "rekor",
    "sigstore",
    "skopeo",
    "slsa",
    "syft",
    "sysusers",
    "toolkits",
    "ublue",
    "ucore",
    "usebottles",
    "uupd",
    "xcursor"
  ],

  "editor.formatOnSave": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.rulers": [80, 100],

  "[shellscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "shellformat.flag": "-i 4 -ci -sr",
  "shellcheck.enable": true,
  "shellcheck.run": "onSave",
  "shellcheck.useWorkspaceRootAsCwd": true,
  "shellcheck.customArgs": ["-S", "warning"],
  "shellcheck.exclude": [],

  "[dockerfile]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "docker.docker"
  },
  "hadolint.hadolintPath": "hadolint",
  "hadolint.cliOptions": [],

  "[yaml]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.validate": true,
  "yaml.format.enable": true,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
    "https://json.schemastore.org/renovate.json": "renovate.json"
  },

  "[toml]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "evenBetterToml.formatter.alignEntries": false,
  "evenBetterToml.formatter.trailingNewline": true,
  "evenBetterToml.schema.enabled": true,

  "[powershell]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.scriptAnalysis.enable": true,

  "[markdown]": {
    "editor.tabSize": 2,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "git.autofetch": true,
  "git.confirmSync": true,
  "git.enableSmartCommit": false,

  "_terminal_comment": "PowerShell is the ONLY terminal profile on Windows. No WSL, no Git Bash, no Cygwin — having those defined at all makes VSCodium and Claude Code pick them up as available shells, and running bare `bash` on Windows spawns external WSL popups. If you need a Linux shell, `wsl` is a one-word command in PowerShell.",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo"]
    },
    "pwsh": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo"]
    },
    "Command Prompt": {
      "path": ["${env:windir}\\System32\\cmd.exe"],
      "icon": "terminal-cmd"
    },
    "Git Bash": null,
    "WSL": null,
    "Ubuntu (WSL)": null,
    "Ubuntu-22.04 (WSL)": null,
    "Ubuntu-24.04 (WSL)": null,
    "Debian (WSL)": null
  },
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.automationProfile.windows": {
    "path": "pwsh.exe",
    "args": ["-NoLogo"]
  },
  "terminal.external.windowsExec": "",

  "_claude_comment": "Pin Claude Code's shell to PowerShell. Multiple key variants because the extension's schema changes across versions — unknown keys ignored, known ones take effect.",
  "claude-code.projectContextFile": "CLAUDE.md",
  "claude-code.enableProjectAgents": true,
  "claude-code.enableSlashCommands": true,
  "claude-code.terminal.integration": "integrated",
  "claude-code.terminal.useIntegrated": true,
  "claude-code.useExternalTerminal": false,
  "claude-code.shell.windows": "powershell",
  "claude-code.preferredShell": "powershell",
  "claude-code.terminal.shell": "powershell",

  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.codeGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" }
  ],

  "geminicodeassist.project": "cloudws-os",
  "geminicodeassist.inlineSuggestions.enableAuto": true,
  "geminicodeassist.enableTelemetry": false
}
