  "editor.formatOnSave": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.rulers": [80, 100],

  "[shellscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "shellformat.flag": "-i 4 -ci -sr",
  "shellcheck.enable": true,
  "shellcheck.run": "onSave",
  "shellcheck.useWorkspaceRootAsCwd": true,
  "shellcheck.customArgs": ["-S", "warning"],
  "shellcheck.exclude": [],

  "[dockerfile]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "docker.docker"
  },
  "hadolint.hadolintPath": "hadolint",
  "hadolint.cliOptions": [],

  "[yaml]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.validate": true,
  "yaml.format.enable": true,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
    "https://json.schemastore.org/renovate.json": "renovate.json"
  },

  "[toml]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "evenBetterToml.formatter.alignEntries": false,
  "evenBetterToml.formatter.trailingNewline": true,
  "evenBetterToml.schema.enabled": true,

  "[powershell]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.autoCorrectAliases": true,
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.scriptAnalysis.enable": true,

  "[markdown]": {
    "editor.tabSize": 2,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "json.schemaDownload.enable": true,

  "git.autofetch": true,
  "git.confirmSync": true,
  "git.enableSmartCommit": false,

  "_terminal_comment": "PowerShell is the ONLY terminal profile on Windows. No WSL, no Git Bash, no Cygwin — having those defined at all makes VSCodium and Claude Code pick them up as available shells, and running bare `bash` on Windows spawns external WSL popups. If you need a Linux shell, `wsl` is a one-word command in PowerShell.",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo"]
    },
    "pwsh": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo"]
    },
    "Command Prompt": {
      "path": ["${env:windir}\\System32\\cmd.exe"],
      "icon": "terminal-cmd"
    },
    "Git Bash": null,
    "WSL": null,
    "Ubuntu (WSL)": null,
    "Ubuntu-22.04 (WSL)": null,
    "Ubuntu-24.04 (WSL)": null,
    "Debian (WSL)": null
  },
  "terminal.integrated.inheritEnv": true,
  "terminal.integrated.automationProfile.windows": {
    "path": "pwsh.exe",
    "args": ["-NoLogo"]
  },
  "terminal.external.windowsExec": "",

  "_claude_comment": "Pin Claude Code's shell to PowerShell. Multiple key variants because the extension's schema changes across versions — unknown keys ignored, known ones take effect.",
  "claude-code.projectContextFile": "CLAUDE.md",
  "claude-code.enableProjectAgents": true,
  "claude-code.enableSlashCommands": true,
  "claude-code.terminal.integration": "integrated",
  "claude-code.terminal.useIntegrated": true,
  "claude-code.useExternalTerminal": false,
  "claude-code.shell.windows": "powershell",
  "claude-code.preferredShell": "powershell",
  "claude-code.terminal.shell": "powershell",

  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.codeGeneration.instructions": [
    { "file": ".github/copilot-instructions.md" }
  ],

  "geminicodeassist.project": "cloudws-os",
  "geminicodeassist.inlineSuggestions.enableAuto": true,
  "geminicodeassist.enableTelemetry": false,

  "terminal.integrated.env.linux": {
    "AI_ARCH_BASELINE": "v2.3.5",
    "AI_DNF_POLICY": "--setopt=install_weak_deps=False",
    "AI_WSL_GATING": "ConditionVirtualization=!wsl",
    "AI_OVERLAY_PATH": "system_files/",
    "AI_PKG_SOURCE": "docs/PACKAGES.md",
    "AI_COSIGN_PIN": "v2.6.3",
    "AI_WORKSPACE_TYPE": "bootable-container",
    "AI_JOURNALING_LAW": "MANDATORY"
  },
  "terminal.integrated.env.windows": {
    "AI_ARCH_BASELINE": "v2.3.5",
    "AI_DNF_POLICY": "--setopt=install_weak_deps=False",
    "AI_WSL_GATING": "ConditionVirtualization=!wsl",
    "AI_OVERLAY_PATH": "system_files/",
    "AI_PKG_SOURCE": "docs/PACKAGES.md",
    "AI_COSIGN_PIN": "v2.6.3",
    "AI_WORKSPACE_TYPE": "bootable-container",
    "AI_JOURNALING_LAW": "MANDATORY"
  }
}
