{
  "_comment": "VSCodium / VSCode workspace settings for CloudWS-bootc. WSL terminal profile removed — having it defined at all causes VSCodium to prefer it when extensions request 'a shell,' and Windows routes bare `bash` through WSL which spawns external popups. On a Windows 11 host, everything runs through PowerShell. Run shell tasks inside WSL manually with `wsl` if needed.",

  "files.associations": {
    "Containerfile": "dockerfile",
    "*.toml": "toml",
    "kargs.d/*.toml": "toml",
    "kargs.d/*": "toml",
    "*.ps1": "powershell",
    "Justfile": "makefile",
    "scripts/cloudws-*": "shellscript",
    "system_files/usr/libexec/cloudws/*": "shellscript",
    "system_files/usr/bin/gamescope-session-steam": "shellscript",
    "system_files/usr/local/bin/cloudws-ceph": "shellscript",
    "system_files/etc/greenboot/check/wanted.d/*": "shellscript"
  },

  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/build": true,
    "**/output": true,
    "**/*.qcow2": true,
    "**/*.vhdx": true,
    "**/*.iso": true,
    "**/*.raw": true
  },

  "search.exclude": {
    "**/.git": true,
    "**/build": true,
    "**/output": true,
    "**/*.qcow2": true,
    "**/*.vhdx": true,
    "**/*.iso": true,
    "**/*.raw": true,
    "docs/knowledge/blueprints/*.docx": true
  },

