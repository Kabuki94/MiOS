# ============================================
# AI Studio (Default) - Required
# ============================================
# Get your API key from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_AI_STUDIO_API_KEY_HERE

# ============================================
# OpenAI API / LiteLLM Proxy standard endpoints
# ============================================
# Uncomment and set these to use self hosted API key instances natively 
# (e.g., OpenWebUI, vLLM, LiteLLM) conforming to OpenAI standards.
# OPENAI_API_KEY=your-openai-or-proxy-api-key
# OPENAI_BASE_URL=http://localhost:4000/v1
